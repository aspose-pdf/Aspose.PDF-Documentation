{
  "api": {
    "baseUrl": "https://llm.professionalize.com/v1",
    "apiKeyEnv": "COMPATIBLE_API_KEY",
    "model": "gpt-oss",
    "timeoutSeconds": 180
  },
  "frontMatter": {
    "translateFields": [
      "title",
      "linktitle",
      "description",
      "summary",
      "AlternativeHeadline",
      "Abstract"
    ]
  },
  "protect": {
    "shortcodes": true,
    "codeBlocks": true,
    "inlineCode": true,
    "urls": true,
    "rawHtml": true,
    "referenceLinks": true
  },
  "warmup": {
    "largeDocumentLength": 20000,
    "largeCodeFenceCount": 12,
    "mediumDocumentLength": 8000,
    "mediumCodeFenceCount": 6,
    "mediumShortcodeCount": 8,
    "largeMaxTexts": 16,
    "largeMaxBatchItems": 2,
    "largeMaxBatchCharacters": 400,
    "mediumMaxTexts": 80,
    "mediumMaxBatchItems": 4,
    "mediumMaxBatchCharacters": 800,
    "smallMaxTexts": 200,
    "smallMaxBatchItems": 6,
    "smallMaxBatchCharacters": 1200
  },
  "glossary": {
    "Documentize": "Documentize",
    "PDF": "PDF",
    "PDF/UA": "PDF/UA",
    "AcroForm": "AcroForm",
    "Aspose.PDF": "Aspose.PDF",
    "Aspose.PDF for Python via .NET": "Aspose.PDF for Python via .NET",
    "Tagged PDF": "Tagged PDF",
    "Structure Elements": "Structure Elements",
    "ITaggedContent": "ITaggedContent",
    "NuGet": "NuGet",
    "Hugo": "Hugo",
    "TextFragment": "TextFragment",
    "TextFragmentAbsorber": "TextFragmentAbsorber",
    "TextFragmentCollection": "TextFragmentCollection",
    "Page": "Page",
    "PageCollection": "PageCollection",
    "ParagraphAbsorber": "ParagraphAbsorber",
    "Paragraph": "Paragraph",
    "Image": "Image"
  }
}